{
  "name": "btx-blue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "cf:dev": "pnpm build && wrangler dev",
    "build": "astro build",
    "deploy": "pnpm build && wrangler deploy",
    "preview": "astro preview",
    "deps:visual": "node ./scripts/deps-visual-check.mjs",
    "deps:visual:preview": "astro preview --host 127.0.0.1 --port 4321",
    "deps:visual:install-browser": "playwright install chromium",
    "check": "astro check",
    "test": "vitest run",
    "test:e2e": "pnpm build && node scripts/run-e2e.mjs",
    "verify": "pnpm check && pnpm test && pnpm build"
  },
  "dependencies": {
    "astro": "^6.1.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@playwright/test": "^1.59.1",
    "@techandsoftware/teletext-fonts": "^1.0.0",
    "@types/node": "^25.6.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.83.0"
  }
}
