---
import BtxScreen from "@/components/btx/BtxScreen.astro";
import BtxLayout from "@/layouts/BtxLayout.astro";
import { getMainPageDefinitions, getRenderedPage } from "@/lib/btx/page-registry";
import { searchIndex } from "@/lib/btx/search";

export function getStaticPaths() {
  return getMainPageDefinitions().map((page) => ({
    params: {
      page: page.id,
    },
  }));
}

const pageNumber = Astro.params.page as `${number}${number}${number}`;
const page = getRenderedPage({ page: pageNumber });

if (!page) {
  throw new Error(`Seite ${pageNumber} fehlt.`);
}
---

<BtxLayout title={`BTX Blue ${page.id}`} description={`${page.title} auf BTX Blue`}>
  <BtxScreen page={page} searchIndex={page.id === "800" ? searchIndex : []} />
</BtxLayout>
