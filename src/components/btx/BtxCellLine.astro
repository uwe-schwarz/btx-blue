---
interface Props {
  columns?: number;
  text?: string;
}

const { columns = 40, text = "" } = Astro.props;
const cells = Array.from(text.padEnd(columns, " ").slice(0, columns));
---

<span class="btx-cell-line" style={`--btx-line-columns:${columns}`}>
  {cells.map((cell) => (
    <span class="btx-cell" aria-hidden="true">{cell === " " ? "\u00a0" : cell}</span>
  ))}
</span>
