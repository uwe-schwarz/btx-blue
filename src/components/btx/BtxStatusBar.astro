---
interface Props {
  currentPage: string;
}

const { currentPage } = Astro.props;
---

<div class="btx-status-line">
  <span class="btx-status-page">SEITE {currentPage}</span>
  <form class="btx-nav-form" data-btx-nav-form>
    <label class="sr-only" for="btx-nav-input">Seite eingeben</label>
    <span class="btx-status-prompt">EINGABE</span>
    <input
      id="btx-nav-input"
      class="btx-nav-input"
      type="text"
      inputmode="numeric"
      maxlength="3"
      autocomplete="off"
      spellcheck="false"
      aria-label="Dreistellige Seitennummer"
      data-btx-nav-input
    />
  </form>
  <div class="btx-status-links">
    <a class="btx-status-link" href="/000" aria-label="Home" data-btx-command="home">#H</a>
    <a class="btx-status-link" href="/800" aria-label="Suche" data-btx-command="search">*S</a>
    <button class="btx-status-link btx-status-link--button" type="button" data-btx-back-button aria-label="Zurueck" data-btx-command="back">
      *Z
    </button>
  </div>
</div>
