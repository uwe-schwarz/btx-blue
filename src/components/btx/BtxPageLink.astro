---
interface Props {
  ariaLabel?: string;
  route: string;
  text: string;
  tone?: "default" | "accent" | "success";
}

const { ariaLabel, route, text, tone = "success" } = Astro.props;
---

<a class={`btx-line btx-line--link btx-line--${tone}`} href={route} aria-label={ariaLabel ?? text} data-btx-noise-text={text}>{text}</a>
