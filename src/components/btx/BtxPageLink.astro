---
import BtxCellLine from "@/components/btx/BtxCellLine.astro";

interface Props {
  ariaLabel?: string;
  route: string;
  text: string;
  tone?: "default" | "accent" | "success";
}

const { ariaLabel, route, text, tone = "success" } = Astro.props;
---

<a class={`btx-line btx-line--link btx-line--${tone}`} href={route} aria-label={ariaLabel}>
  <BtxCellLine text={text} />
</a>
